{
    "configurations": [
        {
            "name": "STM32H750",
            "compileCommands": "${workspaceFolder}/compile_commands.json",
            "includePath": [
               "${workspaceFolder}/**"
            ],
            "defines": [
                "STM32H750xx",
                "USE_HAL_DRIVER",
                "USE_PWR_LDO_SUPPLY",
                "DEBUG",
                "LV_CONF_INCLUDE_SIMPLE"
            ],
            "compilerPath": "/usr/bin/arm-none-eabi-gcc",
            "cStandard": "gnu11",
            "intelliSenseMode": "gcc-arm"
        }
    ],
    "version": 4
}
